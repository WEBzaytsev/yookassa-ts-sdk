{
    "name": "@webzaytsev/yookassa-ts-sdk",
    "version": "3.5.1",
    "description": "TypeScript SDK for the YooKassa API with retries, idempotence helpers, rate limiting, proxy support, and Bun/Node compatibility.",
    "author": "WEBzaytsev <@WEBzaytsev>",
    "contributors": [
        "Dmitriy <@Mityayka1>",
        "Aleksey Aleksyuk <@awardix>"
    ],
    "maintainers": [
        "WEBzaytsev <@WEBzaytsev>"
    ],
    "keywords": [
        "yookassa",
        "yookassa-sdk",
        "yookassa-ts",
        "yookassa-api",
        "payment",
        "refunds",
        "receipts",
        "payments",
        "sberpay",
        "T-pay",
        "yandexpay",
        "SBP",
        "api",
        "typescript",
        "javascript",
        "nodejs",
        "node",
        "bun",
        "sdk",
        "russia",
        "russian-payments",
        "e-commerce",
        "ecommerce",
        "online-payments",
        "checkout",
        "payment-processing",
        "proxy"
    ],
    "private": false,
    "license": "MIT",
    "packageManager": "pnpm@9.15.4",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "docs",
        "examples",
        "README.md",
        "README.ru.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/WEBzaytsev/yookassa-ts-sdk.git"
    },
    "bugs": {
        "url": "https://github.com/WEBzaytsev/yookassa-ts-sdk/issues"
    },
    "homepage": "https://github.com/WEBzaytsev/yookassa-ts-sdk#readme",
    "scripts": {
        "build": "tsup",
        "prepublishOnly": "pnpm run build",
        "test": "bun run src/tests/man-tests.ts",
        "lint": "biome check src/",
        "lint:fix": "biome check --write src/",
        "format": "biome format --write src/",
        "knip": "knip",
        "check": "pnpm run knip && pnpm run lint && tsc --noEmit",
        "docs:api": "typedoc"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "dependencies": {
        "axios": "1.17.0",
        "axios-logger": "2.8.1",
        "axios-rate-limit": "1.9.0",
        "https-proxy-agent": "9.1.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.0",
        "@types/node": "25.9.3",
        "knip": "6.16.1",
        "tsup": "8.5.1",
        "typedoc": "0.28.19",
        "typedoc-plugin-markdown": "4.12.0",
        "typescript": "6.0.3"
    },
    "pnpm": {
        "overrides": {
            "esbuild": "0.28.1"
        }
    }
}
