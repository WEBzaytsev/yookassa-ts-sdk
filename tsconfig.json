{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "removeComments": false,
    "allowSyntheticDefaultImports": true,
    "target": "ES6",
    "baseUrl": "./",
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true
  },
  "exclude": ["yoocheckout-main", "node_modules", "dist", "generated", "examples"]
}
